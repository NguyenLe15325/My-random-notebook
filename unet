aLoader(val_dataset, batch_size=8, shuffle=False, num_workers=2)\n\nprint(f\"Symmetric Loaders ready. Train batches: {len(train_loader)} | Val batches: {len(val_loader)}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-26T14:37:54.395564Z","iopub.execute_input":"2026-06-26T14:37:54.396473Z","iopub.status.idle":"2026-06-26T14:37:54.428186Z","shell.execute_reply.started":"2026-06-26T14:37:54.39644Z","shell.execute_reply":"2026-06-26T14:37:54.42745Z"}},"outputs":[{"name":"stdout","text":"Symmetric Loaders ready. Train batches: 375 | Val batches: 85\n","output_type":"stream"}],"execution_count":3},{"cell_type":"code","source":"# ==============================================================================\n# CELL 3: MODERN PADDED U-NET ARCHITECTURE DEFINITION\n# ==============================================================================\nclass ConvBlock(nn.Module):\n    \"\"\"(Conv 3x3 -> BatchNorm -> ReLU) * 2 with padding=1 to preserve dimensions\"\"\"\n    def __init__(self, in_channels, out_channels):\n        super().__init__()\n        self.conv = nn.Sequential(\n            nn.Conv2d(in_channels, out_channels, kernel_size=3, padding=1, bias=False),\n            nn.BatchNorm2d(out_channels),\n            nn.ReLU(inplace=True),\n            nn.Conv2d(out_channels, out_channels, kernel_size=3, padding=1, bias=False),\n            nn.BatchNorm2d(out_channels),\n            nn.ReLU(inplace=True)\n        )\n    def forward(self, x): \n        return self.conv(x)\n\nclass UNetModern(nn.Module):\n    def __init__(self, in_channels=3, out_channels=3):\n        super().__init__()\n        # Encoder (Downsampling)\n        self.down1 = ConvBlock(in_channels, 64)\n        self.down2 = ConvBlock(64, 128)\n        self.down3 = ConvBlock(128, 256)\n        self.down4 = ConvBlock(256, 512)\n        self.pool = nn.MaxPool2d(kernel_size=2, stride=2)\n        \n        # Bottleneck\n        self.bottleneck = ConvBlock(512, 1024)\n        \n        # Decoder (Upsampling)\n        self.up4 = nn.ConvTranspose2d(1024, 512, kernel_size=2, stride=2)\n        self.dec4 = ConvBlock(1024, 512)\n        \n        self.up3 = nn.ConvTranspose2d(512, 256, kernel_size=2, stride=2)\n        self.dec3 = ConvBlock(512, 256)\n        \n        self.up2 = nn.ConvTranspose2d(256, 128, kernel_size=2, stride=2)\n        self.dec2 = ConvBlock(256, 128)\n        \n        self.up1 = nn.ConvTranspose2d(128, 64, kernel_size=2, stride=2)\n        self.dec1 = ConvBlock(128, 64)\n        \n        self.final_conv = nn.Conv2d(64, out_channels, kernel_size=1)\n\n    def forward(self, x):\n        # Encoder\n        c1 = self.down1(x)\n        p1 = self.pool(c1)\n        \n        c2 = self.down2(p1)\n        p2 = self.pool(c2)\n        \n        c3 = self.down3(p2)\n        p3 = self.pool(c3)\n        \n        c4 = self.down4(p3)\n        p4 = self.pool(c4)\n        \n        # Bottleneck\n        b = self.bottleneck(p4)\n        \n        # Decoder with perfect uncropped skip connections\n        x = self.up4(b)\n        x = torch.cat([c4, x], dim=1)\n        x = self.dec4(x)\n        \n        x = self.up3(x)\n        x = torch.cat([c3, x], dim=1)\n        x = self.dec3(x)\n        \n        x = self.up2(x)\n        x = torch.cat([c2, x], dim=1)\n        x = self.dec2(x)\n        \n        x = self.up1(x)\n        x = torch.cat([c1, x], dim=1)\n        x = self.dec1(x)\n        \n        return self.final_conv(x)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-26T14:37:59.052887Z","iopub.execute_input":"2026-06-26T14:37:59.053542Z","iopub.status.idle":"2026-06-26T14:37:59.065212Z","shell.execute_reply.started":"2026-06-26T14:37:59.053512Z","shell.execute_reply":"2026-06-26T14:37:59.064071Z"}},"outputs":[],"execution_count":4},{"cell_type":"code","source":"# ==============================================================================\n# CELL 4: THE HYBRID DICE + CROSS-ENTROPY LOSS FUNCTION\n# ==============================================================================\nclass DiceLoss(nn.Module):\n    def __init__(self, num_classes=3):\n        super().__init__()\n        self.num_classes = num_classes\n\n    def forward(self, logits, target):\n        probs = torch.softmax(logits, dim=1)\n        target_one_hot = nn.functional.one_hot(target, num_classes=self.num_classes).permute(0, 3, 1, 2).float()\n        \n        smooth = 1e-6\n        intersection = torch.sum(probs * target_one_hot, dim=(2, 3))\n        cardinality = torch.sum(probs + target_one_hot, dim=(2, 3))\n        \n        dice = (2. * intersection + smooth) / (cardinality + smooth)\n        return 1.0 - dice.mean()\n\nclass CombinedLoss(nn.Module):\n    def __init__(self):\n        super().__init__()\n        self.ce = nn.CrossEntropyLoss()\n        self.dice = DiceLoss()\n        \n    def forward(self, logits, target):\n        return self.ce(logits, target) + self.dice(logits, target)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-26T14:38:12.311954Z","iopub.execute_input":"2026-06-26T14:38:12.31226Z","iopub.status.idle":"2026-06-26T14:38:12.318985Z","shell.execute_reply.started":"2026-06-26T14:38:12.312235Z","shell.execute_reply":"2026-06-26T14:38:12.318078Z"}},"outputs":[],"execution_count":6},{"cell_type":"code","source":"# ==============================================================================\n# CELL 5: PRODUCTION RUN METRIC EXECUTION LOOP\n# ==============================================================================\nprint(\"\\n--- Initializing Modern Padded U-Net & Optimizers ---\")\nmodel = UNetModern(in_channels=3, out_channels=3).to(device)\ncriterion = CombinedLoss()\noptimizer = optim.Adam(model.parameters(), lr=1e-4)\n\nepochs = 3 \ntotal_train_batches = len(train_loader)\n\nprint(f\"Beginning 3 training cycles. Expected total runtime: ~10 minutes on T4.\")\n\nfor epoch in range(epochs):\n    # --- TRAINING PHASE ---\n    model.train()\n    train_loss = 0.0\n    pr